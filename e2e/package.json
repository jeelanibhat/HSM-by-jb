{
  "name": "@hotelos/e2e",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "//": "NOT called `test`. `turbo run test` is the fast, hermetic gate — a Playwright suite that needs Postgres and two production servers has no business being dragged into it.",
    "e2e": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "postgres": "^3.4.5",
    "typescript": "^5.7.3"
  }
}
