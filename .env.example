# Copy to .env and adjust. Never commit .env.
NODE_ENV=development

# Postgres (matches compose.yaml).
#
# TWO roles, on purpose:
#   hotelos_app  runtime. Unprivileged, NOBYPASSRLS, owns nothing.
#   hotelos      owner/superuser. Migrations ONLY.
#
# The app must never connect as the owner: superusers and table owners bypass
# Row-Level Security, which would silently disable all tenant isolation. The API
# refuses to boot if DATABASE_URL points at the owner role.
DATABASE_URL=postgresql://hotelos_app:hotelos_app@localhost:5432/hotelos
DATABASE_MIGRATION_URL=postgresql://hotelos:hotelos@localhost:5432/hotelos

# Valkey — BSD-licensed Redis drop-in (sessions, cache, GraphQL subscription pub/sub)
VALKEY_URL=redis://localhost:6379

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=dev-only-access-secret-change-me
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me

# Guest PII encryption at rest (TDD §9). Two DIFFERENT 32-byte keys, base64.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# PII_ENCRYPTION_KEY encrypts id_number (AES-256-GCM).
# PII_HASH_KEY keys the blind index that makes exact ID lookup possible without
# decrypting. Sharing one key across both purposes is how a weakness in one
# becomes a weakness in both.
#
# Lose PII_ENCRYPTION_KEY and every stored ID number is gone for good. Back it up
# somewhere that is not the database backup.
PII_ENCRYPTION_KEY=REPLACE_ME_32_BYTES_BASE64_AAAAAAAAAAAAAAAAAAA=
PII_HASH_KEY=REPLACE_ME_A_DIFFERENT_32_BYTES_BASE64_AAAAAAAA=

# Web
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
